{
  "name": "@silverorange-inc/eslint-config-node",
  "version": "1.0.2",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "README.md",
    "dist/"
  ],
  "engines": {
    "node": "^22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/silverorange/silverorange-eslint-config.git",
    "directory": "packages/node"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist && rm tsconfig.tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "typescript-eslint": "^8.59.3"
  },
  "peerDependencies": {
    "eslint": "catalog:"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
