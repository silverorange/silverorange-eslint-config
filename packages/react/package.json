{
  "name": "@silverorange-inc/eslint-config-react",
  "version": "2.4.0",
  "type": "module",
  "types": "src/index.ts",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./config": {
      "types": "./src/configs/react.ts",
      "import": "./src/configs/react.ts"
    }
  },
  "files": [
    "README.md",
    "dist/"
  ],
  "engines": {
    "node": "^22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/silverorange/silverorange-eslint-config.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public",
    "types": "dist/index.d.ts",
    "main": "dist/index.js",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./config": {
        "types": "./dist/configs/react.d.ts",
        "import": "./dist/configs/react.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist && rm tsconfig.tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@silverorange-inc/eslint-config-node": "workspace:*",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1"
  },
  "peerDependencies": {
    "eslint": "catalog:"
  },
  "devDependencies": {
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
